{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      // Root-level site.config.ts (the @aicompany/core host config) importable
      // from anywhere as `import { siteConfig } from "site.config"`.
      "site.config": ["./site.config.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "packages/brain",
    // The module's test suite runs from packages/aicompany with its own
    // devDependencies (vitest) — not installed at the host root.
    "packages/aicompany/tests",
    "packages/aicompany/vitest.config.ts"
  ]
}
