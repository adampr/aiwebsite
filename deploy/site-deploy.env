# Host deploy configuration for @aicompany/core's deploy templates
# (packages/aicompany/architecture.md §9). Values here are aiwebsite's real
# ones (ARCHITECTURE.md §2/§9/§10). Re-render after any change:
#   node packages/aicompany/deploy/render.mjs
# and COMMIT the rendered deploy/ files — deploy.sh verifies their template
# stamps against the module and fails on drift.
#
# Values are read literally (KEY=VALUE, no shell expansion, optional quotes).
# Machine SECRETS never live in this file: SSH IP/user/password/key-path live
# in the dev box's .env under AIWEBSITE_* (read literally, never sourced).

# ── Identity ─────────────────────────────────────────────────────
# Must equal site.config.ts site.slug. Names the PM2 app, the Postgres
# role/db, systemd units, log files, and the "[aiwebsite] <SEVERITY>"
# alert-subject prefix.
SLUG=aiwebsite
# Public hostname served by the Cloudflare tunnel (no scheme).
DOMAIN=ai.xl.net

# ── VM layout ────────────────────────────────────────────────────
# Azure VM (xladmin@…, coordinates in .env under AIWEBSITE_*).
APP_DIR=/var/www/aiwebsite
# Loopback ports (ARCHITECTURE.md §2 port map).
APP_PORT=3000
BRAIN_PORT=3211
SKILLS_PORT=3213
# Path of this module inside the host repo (submodule mount point).
MODULE_DIR=packages/aicompany

# ── Cloudflare tunnel ────────────────────────────────────────────
# Named tunnel "aiwebsite", ID 8dbfd62e-eb42-4589-8b76-d1edc77cd018.
# Credentials JSON ships from the dev box as ~/.cloudflared/aiwebsite-tunnel.json.
# DNS (CNAME ai → 8dbfd62e-eb42-4589-8b76-d1edc77cd018.cfargotunnel.com,
# Proxied, xl.net zone) is a HUMAN step — deploy scripts never write DNS.
TUNNEL_NAME=aiwebsite

# ── Alerting (module §9.5 convention) ────────────────────────────
# Recipient of watchdog / backup / restore-drill / disk alerts — matches
# site.config.ts oversight.alertEmail.
ALERT_EMAIL=adam@xl.net
# From header for those alerts (verified Resend sender on ai.xl.net) —
# legacy watchdog.sh value, ported verbatim.
ALERT_FROM=ai.xl.net Watchdog <noreply@ai.xl.net>

# ── Deploy transport (module §9.2) ───────────────────────────────
# sshpass = the VM's current password-auth reality (legacy deploy.sh used
# AIWEBSITE_PW the same way); deploy.sh refuses to run without an explicit
# --allow-sshpass flag. RECOMMENDED SWITCH: provision an SSH key on the VM,
# set AIWEBSITE_SSH_KEY in .env (or rely on SSH_KEY_PATH below), and change
# this to ssh-key.
DEPLOY_TRANSPORT=sshpass
# Default SSH private key path on the dev box once ssh-key transport is
# adopted; AIWEBSITE_SSH_KEY in .env overrides it. Leading ~ expanded by
# deploy.sh itself — do not quote.
SSH_KEY_PATH=~/.ssh/id_ed25519
# Prefix of the dev-box .env entries holding VM coordinates:
# AIWEBSITE_SSH_IP / AIWEBSITE_USER / AIWEBSITE_PW (sshpass) or
# AIWEBSITE_SSH_KEY (ssh-key).
ENV_PREFIX=AIWEBSITE
# gcloud-iap transport only (this is an Azure VM — leave blank).
GCLOUD_PROJECT=
GCLOUD_ZONE=
GCLOUD_VM_NAME=

# ── Backups (module §9.4, default-on invariant) ──────────────────
# TODO(go-live): no backup bucket exists for aiwebsite yet. The rendered
# backup-db.sh/restore-drill.sh reject an empty/unsupported bucket and the
# ERR trap emails ALERT_EMAIL "[aiwebsite] CRITICAL Database backup FAILED"
# on every nightly timer fire until one is provisioned — loud by design
# (there is no opt-out flag). Provision Azure Blob (VM is Azure):
#   BACKUP_BUCKET=azblob://<storage-account>/<container>   (az login identity)
# or GCS: BACKUP_BUCKET=gs://<bucket>[/prefix] — then re-render + redeploy.
BACKUP_BUCKET=

# ── Retention windows, days (module §9.5) ────────────────────────
# MUST match privacy.retentionDays in site.config.ts — the privacy page and
# the sweeper must never disagree. sms_consent_logs is exempt by design.
RETAIN_PAGE_VISITS_DAYS=730
RETAIN_AUTH_LOGS_DAYS=365
RETAIN_IP_ORGS_DAYS=730
RETAIN_ADMIN_EMAILS_DAYS=730
SEED_MODE=file

# ── Blog / SEO content engine (module §19, v1.0.1+) ──────────────
# aiwebsite has NOT adopted the blog engine — no `blog` config block, no
# blog wrapper routes. 0 = the rendered setup-vm.sh/watchdog.sh skip the
# nightly systemd timer entirely. Flip per MIGRATIONS.md v1.0.1 steps 3-6.
BLOG_ENABLED=0
# Nightly generate/refresh window (systemd OnCalendar); unused while
# BLOG_ENABLED=0 but render.mjs requires the key.
BLOG_ONCALENDAR=*-*-* 09:30:00 UTC
