{
  "name": "aiwebsite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks || true",
    "dev": "next dev",
    "build": "NEXT_PUBLIC_BUILD_ID=$(date +%s) next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
