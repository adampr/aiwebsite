    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "maxmind": "^5.0.6",
    "mmdb-lib": "^3.0.2",
    "next": "16.2.9",
    "pdfjs-dist": "^6.1.200",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.1",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1"
