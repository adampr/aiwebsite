  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5"
  }
