# ── Database (site + brain share one Postgres DB) ────────────────
DATABASE_URL=postgresql://aiwebsite:aiwebsite@localhost:5432/aiwebsite

# ── Brain (runs locally from packages/brain submodule via PM2) ───
# Since brain v1.89 the API is fail-closed: BRAIN_API_KEYS is REQUIRED
# (comma-separated Bearer keys; the site sends the first one — see
# src/lib/brain-client.ts). Only /twilio/* webhooks are publicly reachable
# (via nginx + Cloudflare tunnel) and those validate Twilio signatures.
BRAIN_API_KEYS=
BRAIN_BASE_URL=http://127.0.0.1:3211
BRAIN_PUBLIC_URL=https://ai.xl.net/brain
BRAIN_DB_BACKEND=postgres
BRAIN_POSTGRES_URL=postgresql://aiwebsite:aiwebsite@localhost:5432/aiwebsite
BRAIN_DB_TABLE_PREFIX=brain_
BRAIN_AUDIO_MODE=xai_realtime

# ── LLM / voice providers (required for chat + phone) ────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Fast first-pass pin (brain v1.90+): REQUIRED for snappy chat. Without it the
# brain's first pass falls back to OPENAI_MODEL (gpt-5-mini, a reasoning
# model) and a simple "Hello" takes 10-50s instead of ~1-2s.
BRAIN_FIRST_PASS_MODEL=gpt-5.4-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-1
XAI_API_KEY=
# Optional providers
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
TAVILY_API_KEY=
AA_API_KEY=

# ── Twilio (phone number for the Tron Netter voice agent) ────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Inbound call persona
INBOUND_PHONE_PERSONA_NAME=Tron Netter
INBOUND_PHONE_SITE=ai.xl.net
INBOUND_PHONE_GREETING=Thank you for calling XL.net, this is Tron Netter. How can I help you today?

# ── Email (Resend; domain ai.xl.net must be verified in Resend) ──
RESEND_API_KEY=
MAIL_FROM=Tron Netter <Tron.Netter@ai.xl.net>
CONTACT_NOTIFY_EMAIL=ai@xl.net
# Svix signing secret for the inbound-email webhook (/api/webhooks/resend);
# from the Resend dashboard webhook settings.
RESEND_WEBHOOK_SECRET=
# Every outbound email is BCC'd here for human oversight (do not remove).
# Defaults to adam@xl.net when unset (src/lib/email/send.ts).
OUTBOUND_BCC_EMAIL=adam@xl.net
# Recipient for the nightly knowledge-refresh report; falls back to
# ADMIN_EMAIL, then adam@xl.net (scripts/refresh-tron-knowledge.mjs).
KNOWLEDGE_NOTIFY_EMAIL=

# ── OAuth sign-in (see deploy/GOOGLE-OAUTH-SETUP.md) ──────────────
# Google web client "ai.xl.net" in GCP project xl-website-1682362315172.
# Unset = "Continue with Google" shows an unavailable message.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ai.xl.net/auth/google/callback
# Microsoft Entra app e66a2e8f-c1c1-4b63-9ffe-245db7d5363c.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://ai.xl.net/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
# Comma-separated emails treated as admins by /api/auth/session, the /admin
# pages, and the /api/admin/* routes (src/lib/auth.ts isAdmin()).
ADMIN_EMAIL=adam@xl.net

# ── Secrets (generate with: openssl rand -hex 32) ─────────────────
SESSION_COOKIE_SECRET=
AUTOMATION_SECRET=
# Auth for middleware→/api/internal/track page-view beacons. UNSET disables
# visit tracking entirely (and /admin/seo + /admin/companies stay empty).
INTERNAL_TRACK_SECRET=

# ── Visitor identification (/admin/companies) ─────────────────────
# MaxMind GeoLite2-ASN database for IP→organization lookups. Gitignored;
# deploy.sh ships it. Defaults to <cwd>/data/GeoLite2-ASN.mmdb.
#MAXMIND_DB_PATH=

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://ai.xl.net
NEXT_PUBLIC_SITE_NAME=XL.net AI
# Optional override for the persona knowledge doc; defaults to
# <cwd>/data/tron-netter-knowledge.md (src/lib/tron-netter/persona.ts).
#TRON_KNOWLEDGE_FILE=

# ── Brain persona defaults (overridden per-request by the site) ───
DEFAULT_BRAIN_NAME=Tron Netter
DEFAULT_PURPOSE=Tron Netter is an AI Agent working for XL.net. He answers questions about XL.net (always saying "we", "us", "our" — he works for XL.net) using only the publicly available content of https://xl.net and https://ai.xl.net. XL.net is a Chicago-based managed IT services provider for small and mid-size businesses. He cannot browse the internet, check weather, or help with unrelated tasks — he politely declines and steers back to XL.net topics.

# ── Deployment (used by deploy/deploy.sh from the dev box) ────────
AIWEBSITE_SSH_IP=
AIWEBSITE_USER=
AIWEBSITE_PW=
