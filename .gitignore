# Secrets — never commit env files, keys, or credentials (CLAUDE.md
# "Never commit secrets"; enforced by scripts/git-hooks/pre-commit).
# deploy/site-deploy.env stays tracked: it is config, holds no secrets.
.env
.env.*
!.env.example
*.pem
*.p12
*.pfx
*.key
id_rsa
id_ed25519
id_ecdsa

# Editor swap/backup files (e.g. ..env.swp from vim editing .env)
*.swp
*.swo
*~

node_modules/
.next/
out/
dist/
*.tsbuildinfo
next-env.d.ts
.DS_Store
# generated nightly by scripts/refresh-tron-knowledge.mjs
/data/

# Self-hosted webinar recording(s): too large for git; deploy.sh rsyncs the
# working tree, so the file ships to the VM from the dev box (ARCHITECTURE.md §5.10).
/public/media/*.mp4
